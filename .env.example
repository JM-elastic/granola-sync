# Google OAuth2 credentials
# Create at: https://console.cloud.google.com/apis/credentials
# Required scopes: https://www.googleapis.com/auth/drive, https://www.googleapis.com/auth/documents
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
GOOGLE_REFRESH_TOKEN=your-refresh-token

# Google Drive destination folder path (created automatically if it doesn't exist)
# Default: meetingnotes/Unsorted
DRIVE_FOLDER=meetingnotes/Unsorted

# Sync interval in minutes (default: 30)
SYNC_INTERVAL_MINUTES=30

# Only sync notes from the last N days (default: 3, set to 0 for all notes)
SYNC_DAYS_BACK=3
