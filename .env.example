# Google OAuth2 credentials
# Create at: https://console.cloud.google.com/apis/credentials
# Required scopes: https://www.googleapis.com/auth/drive, https://www.googleapis.com/auth/documents
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
GOOGLE_REFRESH_TOKEN=your-refresh-token

# ── Folder Sync Mode ──────────────────────────────────────────
# "all"     — sync notes from all Granola folders (default)
# "folders" — sync only from the folders listed in GRANOLA_FOLDERS
GRANOLA_SYNC_MODE=all

# Comma-separated list of Granola folder names to sync
# Only used when GRANOLA_SYNC_MODE=folders
# Example: GRANOLA_FOLDERS=Elastic,Personal
GRANOLA_FOLDERS=

# ── Google Drive Destination ──────────────────────────────────
# Root folder in Google Drive for synced docs (created if it doesn't exist)
# Leave empty to place docs in Drive root
# Granola folder structure is preserved under this root:
#   DRIVE_ROOT/FolderName/2026-04-01 - Meeting Title
#   DRIVE_ROOT/Unsorted/2026-04-01 - Unfiled Meeting
DRIVE_ROOT=meetingnotes

# ── Sync Behavior ─────────────────────────────────────────────
# Minutes between sync cycles in continuous mode (default: 30)
SYNC_INTERVAL_MINUTES=30

# Only sync notes from the last N days (default: 3, set to 0 for all)
SYNC_DAYS_BACK=3
